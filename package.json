{
  "name": "dertinfo-monorepo",
  "private": true,
  "workspaces": [
    "apps/dert-web/src/client",
    "apps/dert-app/src/client"
  ],
  "scripts": {
    "web:install": "npm install --workspace=apps/dert-web/src/client",
    "web:build": "npm run build --workspace=apps/dert-web/src/client",
    "web:lint": "npm run lint --workspace=apps/dert-web/src/client",
    "web:test": "npm run test --workspace=apps/dert-web/src/client",
    "app:install": "npm install --workspace=apps/dert-app/src/client",
    "app:build": "npm run build --workspace=apps/dert-app/src/client",
    "app:lint": "npm run lint --workspace=apps/dert-app/src/client",
    "app:test": "npm run test --workspace=apps/dert-app/src/client"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

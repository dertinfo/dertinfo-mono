# Copy to api.env and fill in values from your Auth0 dev tenant.
# Important: lines must be uncommented — docker env_file ignores # comments.
#
# Auth0:ManagementClientId is already in apps/dert-api/src/dertinfo-api/appsettings.json.
# Only secrets belong here:
Auth0__ManagementClientSecret=
# SendGrid__ApiKey=          # optional; email disabled in compose by default

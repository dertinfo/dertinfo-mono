# Unified Docker Compose environment reference
#
# Copy the per-service example files before running docker compose:
#   cp infra/docker/api.env.example infra/docker/api.env
#   cp infra/docker/web.env.example infra/docker/web.env
#   cp infra/docker/app.env.example infra/docker/app.env
#
# api.env — API secrets for Docker (gitignored). See docs/configuration.md
#   Lines must be uncommented for docker compose to load them.
#   Auth0__ManagementClientSecret=   # required for Auth0 login flows
#   SendGrid__ApiKey=                # optional; email disabled in compose by default
#
# web.env — website runtime config (browser reaches API on host localhost)
#   API_URL=http://localhost:44100/api
#   AUTH_CALLBACK_URL=http://localhost:44200
#   ALLOWED_DOMAINS=localhost:44100
#
# app.env — PWA runtime config
#   API_URL=http://localhost:44100/api
#   AUTH_CALLBACK_URL=http://localhost:44300
#   ALLOWED_DOMAINS=localhost:44100
